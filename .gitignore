# Скомпилированные Python файлы (это автоматически генерируемые компилированные байт-коды Python,
# которые не содержат исходного кода. Они создаются при каждом запуске программы, засоряют репозиторий)
*.pyc

# Папка с кэшем Python (временные файлы интерпретатора)
__pycache__/

# Файлы с переменными окружения (могут содержать секреты и настройки)
.env

# Виртуальное окружение Python (локальные зависимости, содержит тысячи файлов не нужные другим разработчикам)
venv/

# Файлы логов (временные данные, логи ошибок и диогнастическая информация)
*.log

# Папка с собранными пакетами (содержит автоматически сгенерированные файлы сборки (архивы .tar.gz, .whl),
# предназначенные для распространения, а не для разработки.
dist/

# Папка со сборкой проекта (содержит временные файлы, сгенерированные в процессе сборки,
# компиляции или упаковки проекта)
build/

*.pyc
.vscode/

# pytest
.pytest_cache/

# mypy
.mypy_cache/

# Ruff
.ruff_cache/

# IDE
.idea/

# OS
.DS_Store
Thumbs.db

# Coverage
.coverage
htmlcov/

# Alembic
*.db

# Env examples
.env.local

# Educational materials
learning/

# macOS/Linux env
.venv/

# Coverage
.coverage.*
coverage.xml

# Python cache
*.pyo
*.pyd

docs/